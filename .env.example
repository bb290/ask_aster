# Ask Aster v0 — environment variables
#
# For local ingestion (scripts/ingest.ts):
#   export $(grep -v '^#' .env | xargs)
#   deno run --allow-read --allow-env --allow-net scripts/ingest.ts
#
# For the deployed Edge Function, set these as Supabase secrets:
#   supabase secrets set --project-ref ahonotvcbmczrtnpajua \
#     SUPABASE_SERVICE_ROLE_KEY=... OPENROUTER_API_KEY=... ASTER_ACCESS_KEY=...
#
# .env is gitignored; never commit real values.

SUPABASE_URL=https://ahonotvcbmczrtnpajua.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=
ASTER_ACCESS_KEY=
